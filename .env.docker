AXIOM_NEO4J_PASSWORD=rigpa-dev
AXIOM_REDIS_URL=redis://axiom-redis:6379

AXIOM_API_PORT=7200
AXIOM_COUNCIL_PORT=7201
AXIOM_AXIOMATIZER_PORT=7202
AXIOM_WEB_PORT=7100

AXIOM_MODEL_PLANNER=llama3.2:3b
